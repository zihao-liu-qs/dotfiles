#!/bin/bash
# =========================
# Install all tools required by .zshrc
# =========================

set -e

OS="$(uname -s)"

# =========================
# Clear proxy env vars
# ~/.zshrc sets http_proxy/https_proxy to 127.0.0.1:7890 for local use.
# In a container that port doesn't exist — unset them so git/curl work normally.
# =========================
unset http_proxy https_proxy HTTP_PROXY HTTPS_PROXY all_proxy ALL_PROXY

# =========================
# sudo detection
# Runs a command with sudo only when necessary and available.
# In root containers (uid=0) or environments without sudo, runs directly.
# =========================
SUDO=""
if [[ "$EUID" -ne 0 ]]; then
    if command -v sudo &>/dev/null; then
        SUDO="sudo"
    fi
fi

run() {
    $SUDO "$@"
}

# =========================
# macOS: ensure Homebrew
# =========================
if [[ "$OS" == "Darwin" ]]; then
    if ! command -v brew &>/dev/null; then
        echo "Installing Homebrew..."
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    else
        echo "Homebrew is already installed"
    fi
fi

# =========================
# git — install first, many tools depend on it
# =========================
if ! command -v git &>/dev/null; then
    echo "Installing git..."
    if [[ "$OS" == "Darwin" ]]; then
        brew install git
    elif [[ "$OS" == "Linux" ]]; then
        run apt-get install -y git 2>/dev/null || \
        run dnf install -y git 2>/dev/null || \
        run pacman -S --noconfirm git 2>/dev/null || \
        echo "Please install git manually for your Linux distro"
    fi
    echo "git installed successfully"
else
    echo "git is already installed"
fi

# =========================
# zsh (ensure it's available)
# =========================
if ! command -v zsh &>/dev/null; then
    echo "Installing zsh..."
    if [[ "$OS" == "Darwin" ]]; then
        brew install zsh
    elif [[ "$OS" == "Linux" ]]; then
        run apt-get install -y zsh 2>/dev/null || \
        run dnf install -y zsh 2>/dev/null || \
        run pacman -S --noconfirm zsh 2>/dev/null || \
        echo "Please install zsh manually for your Linux distro"
    fi
    echo "zsh installed successfully"
else
    echo "zsh is already installed"
fi

# =========================
# fzf
# =========================
if ! command -v fzf &>/dev/null; then
    echo "Installing fzf..."
    if [[ "$OS" == "Darwin" ]]; then
        brew install fzf
    elif [[ "$OS" == "Linux" ]]; then
        git clone --depth 1 https://github.com/junegunn/fzf.git ~/.fzf
        ~/.fzf/install --all --no-bash --no-fish
    fi
    echo "fzf installed successfully"
else
    echo "fzf is already installed"
fi

# =========================
# zoxide
# =========================
if ! command -v zoxide &>/dev/null; then
    echo "Installing zoxide..."
    if [[ "$OS" == "Darwin" ]]; then
        brew install zoxide
    elif [[ "$OS" == "Linux" ]]; then
        curl -sSf https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | bash
    fi
    echo "zoxide installed successfully"
else
    echo "zoxide is already installed"
fi

# =========================
# neovim
# =========================
if ! command -v nvim &>/dev/null; then
    echo "Installing neovim..."
    if [[ "$OS" == "Darwin" ]]; then
        brew install neovim
    elif [[ "$OS" == "Linux" ]]; then
        # AppImage installs to ~/.local/bin — no sudo needed
        mkdir -p "$HOME/.local/bin"
        curl -Lo "$HOME/.local/bin/nvim" \
            https://github.com/neovim/neovim/releases/latest/download/nvim-linux-x86_64.appimage
        chmod u+x "$HOME/.local/bin/nvim"
        export PATH="$HOME/.local/bin:$PATH"
    fi
    echo "neovim installed successfully"
else
    echo "neovim is already installed"
fi

# =========================
# tmux
# =========================
if ! command -v tmux &>/dev/null; then
    echo "Installing tmux..."
    if [[ "$OS" == "Darwin" ]]; then
        brew install tmux
    elif [[ "$OS" == "Linux" ]]; then
        run apt-get install -y tmux 2>/dev/null || \
        run dnf install -y tmux 2>/dev/null || \
        run pacman -S --noconfirm tmux 2>/dev/null || \
        echo "Please install tmux manually for your Linux distro"
    fi
    echo "tmux installed successfully"
else
    echo "tmux is already installed"
fi

# =========================
# kitty
# =========================
if ! command -v kitty &>/dev/null; then
    echo "Installing kitty..."
    if [[ "$OS" == "Darwin" ]]; then
        brew install --cask kitty
    elif [[ "$OS" == "Linux" ]]; then
        # Prefer system package manager — avoids the upstream installer's .txz/xz dependency.
        # kitty is a GUI terminal; in headless/container environments it installs fine
        # but won't launch without a display — that's expected.
        if command -v apt-get &>/dev/null; then
            run apt-get install -y kitty
        elif command -v dnf &>/dev/null; then
            run dnf install -y kitty
        elif command -v pacman &>/dev/null; then
            run pacman -S --noconfirm kitty
        else
            # Last resort: upstream installer — needs xz to extract the tarball
            if ! command -v xz &>/dev/null; then
                echo "  WARNING: xz not found and no known package manager available."
                echo "  Cannot install kitty automatically."
                echo "  Please install xz-utils or kitty manually: https://sw.kovidgoyal.net/kitty/binary/"
            else
                curl -L https://sw.kovidgoyal.net/kitty/installer.sh | sh /dev/stdin
                mkdir -p "$HOME/.local/bin"
                ln -sf "$HOME/.local/kitty.app/bin/kitty"  "$HOME/.local/bin/kitty"  2>/dev/null || true
                ln -sf "$HOME/.local/kitty.app/bin/kitten" "$HOME/.local/bin/kitten" 2>/dev/null || true
                export PATH="$HOME/.local/bin:$PATH"
            fi
        fi
    fi
    echo "kitty installed successfully"
else
    echo "kitty is already installed"
fi

# =========================
# yazi
# =========================
if ! command -v yazi &>/dev/null; then
    echo "Installing yazi..."
    if [[ "$OS" == "Darwin" ]]; then
        brew install yazi
    elif [[ "$OS" == "Linux" ]]; then
        if command -v cargo &>/dev/null; then
            cargo install --locked yazi-fm yazi-cli
        else
            echo "yazi: cargo not found. Install Rust first:"
            echo "  curl https://sh.rustup.rs -sSf | sh"
            echo "  then: cargo install --locked yazi-fm yazi-cli"
            echo "  or visit: https://yazi-rs.github.io/docs/installation"
        fi
    fi
    echo "yazi installed successfully"
else
    echo "yazi is already installed"
fi

# =========================
# starship prompt
# =========================
if ! command -v starship &>/dev/null; then
    echo "Installing starship..."
    if [[ "$OS" == "Darwin" ]]; then
        brew install starship
    elif [[ "$OS" == "Linux" ]]; then
        # --yes skips prompt; --bin-dir installs to ~/.local/bin (no sudo)
        curl -sS https://starship.rs/install.sh | sh -s -- --yes --bin-dir "$HOME/.local/bin"
        export PATH="$HOME/.local/bin:$PATH"
    fi
    echo "starship installed successfully"
else
    echo "starship is already installed"
fi

# =========================
# Summary
# =========================
echo ""
echo "========================================"
echo " All tools installed. Reload your shell:"
echo "   exec zsh"
echo "========================================"
